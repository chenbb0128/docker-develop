{
    "name": "docker-develop/docker-panel",
    "description": "Docker 管理面板 - 基于 Hyperf 框架",
    "type": "project",
    "keywords": [
        "docker",
        "management",
        "hyperf",
        "swoole"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "hyperf/config": "~3.1.0",
        "hyperf/di": "~3.1.0",
        "hyperf/engine": "^2.10",
        "hyperf/framework": "~3.1.0",
        "hyperf/http-server": "~3.1.0",
        "hyperf/logger": "~3.1.0",
        "hyperf/memory": "~3.1.0",
        "hyperf/session": "~3.1.0",
        "hyperf/view": "~3.1.0",
        "hyperf/view-engine": "~3.1.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "hyperf/devtool": "~3.1.0",
        "hyperf/testing": "~3.1.0",
        "phpstan/phpstan": "^1.0",
        "swoole/ide-helper": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": []
    },
    "autoload-dev": {
        "psr-4": {
            "HyperfTest\\": "test/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "hyperf/plugin-generator": true
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-autoload-dump": [],
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit 512M",
        "cs-fix": "@php vendor/bin/php-cs-fixer fix $1",
        "start": "@php bin/hyperf.php start"
    }
}
