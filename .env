# All Networks driver
NETWORKS_DRIVER=bridge

# 使用docker宿主机ip，否则xdebug+phpstorm的无法断点，也可以改hosts
DOCKER_HOST_IP=host-gateway
TIMEZONE=Asia/Shanghai

# 默认使用仓库内 data 目录，保证新用户 clone 后可以直接启动面板。
# 接入自己的业务项目时，再改成自己的项目根目录，例如 D:\Develop 或 E:\Work。
HOST_PROJECT_PATH=./data
# 容器中文件目录
CONTAINER_PROJECT_PATH=/develop
DATA_PATH=./data


# 更改源加速
CHANGE_SOURCE=true

# docker-panel 基础镜像；Docker Hub 慢时可在本机 .env 改成公司或个人镜像代理。
DOCKER_PANEL_PHP_IMAGE=php:8.3-cli-alpine
DOCKER_PANEL_COMPOSER_IMAGE=composer:2

# All volumes driver
VOLUMES_DRIVER=local

# Oh My ZSH!
SHELL_OH_MY_ZSH=true
SHELL_OH_MY_ZSH_AUTOSUGESTIONS=true
SHELL_OH_MY_ZSH_ALIASES=true

# Select a Phalcon version of the Workspace and PHP-FPM containers (Does not apply to HHVM). Accepted values: 5.0.0+
PHALCON_VERSION=5.0.0

#---------------------------------------------
# PHP-FPM
#---------------------------------------------
PHP_VERSION=8.3
PHP_VERSION_73=7.3
PHP_VERSION_83=8.3
PHP_FPM_INSTALL_MYSQLI=true
PHP_FPM_INSTALL_PDO_MYSQL=true
PHP_FPM_INSTALL_IMAGEMAGICK=true
PHP_FPM_IMAGEMAGICK_VERSION=latest
PHP_FPM_INSTALL_OPCACHE=true
PHP_FPM_INSTALL_IMAGE_OPTIMIZERS=true
PHP_FPM_INSTALL_PHPREDIS=true
PHP_FPM_INSTALL_MEMCACHED=false
PHP_FPM_INSTALL_XDEBUG=false
PHP_FPM_XDEBUG_PORT=9000
PHP_FPM_INSTALL_MONGO=false
PHP_FPM_INSTALL_SWOOLE=true
PHP_FPM_FFMPEG=false
PHP_FPM_INSTALL_EXIF=false
PHP_FPM_INSTALL_PHALCON=false
PHP_FPM_INSTALL_PING=false
PHP_FPM_INSTALL_PHPDECIMAL=false
INSTALL_COMPOSER=true


PHP_FPM_PUID=1000
PHP_FPM_PGID=1000

#---------------------------------------------
# WORKSPACE
#---------------------------------------------
WORKSPACE_PHP_VERSION=8.3
WORKSPACE_INSTALL_XDEBUG=false
WORKSPACE_XDEBUG_PORT=9000
WORKSPACE_INSTALL_MONGO=true
WORKSPACE_INSTALL_PHPREDIS=true
WORKSPACE_INSTALL_COMPOSER=true
WORKSPACE_COMPOSER_GLOBAL_INSTALL=true
WORKSPACE_COMPOSER_VERSION=2
WORKSPACE_COMPOSER_AUTH_JSON=false
WORKSPACE_COMPOSER_REPO_PACKAGIST=https://mirrors.aliyun.com/composer/
WORKSPACE_INSTALL_NODE=true
WORKSPACE_NODE_VERSION=20
WORKSPACE_INSTALL_IMAGEMAGICK=true
WORKSPACE_INSTALL_SWOOLE=true
WORKSPACE_IMAGEMAGICK_VERSION=latest
WORKSPACE_INSTALL_SUPERVISOR=false
WORKSPACE_INSTALL_FFMPEG=false
WORKSPACE_INSTALL_MEMCACHED=false
WORKSPACE_PUID=1000
WORKSPACE_PGID=1000
UBUNTU_VERSION=22.04

#---------------------------------------------
# NGINX
#---------------------------------------------
NGINX_HOST_HTTP_PORT=80
NGINX_HOST_HTTPS_PORT=443
NGINX_HOST_LOG_PATH=./logs/nginx/
NGINX_SITES_PATH=./services/nginx/sites/
NGINX_PHP_UPSTREAM_CONTAINER=php83-fpm
NGINX_PHP_UPSTREAM_PORT=9000
NGINX_SSL_PATH=./services/nginx/ssl/

#---------------------------------------------
# MYSQL
#---------------------------------------------
MYSQL_VERSION=latest
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456
MYSQL_HOST_DATA_PATH=./data/mysql
MYSQL_CONTAINER_DATA_PATH=/var/lib/mysql
MYSQL_DATABASE=default
MYSQL_PORT=3306
MYSQL_ENTRYPOINT_INITDB=./services/mysql/docker-entrypoint-initdb.d

#---------------------------------------------
# REDIS
#---------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=123456

#---------------------------------------------
# RABBITMQ
#---------------------------------------------
RABBITMQ_NODE_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HTTP_HOST_PORT=15672
RABBITMQ_MANAGEMENT_HTTPS_HOST_PORT=15671
RABBITMQ_WEB_STOMP_HOST_PORT=15674

#---------------------------------------------
# ELASTICSEARCH
#---------------------------------------------
ELASTICSEARCH_HOST_HTTP_PORT=9200
ELASTICSEARCH_HOST_TRANSPORT_PORT=9300
ELK_VERSION=7.9.1

#---------------------------------------------
# MEMCACHED
#---------------------------------------------
MEMCACHED_HOST_PORT=11211

#---------------------------------------------
# MONGODB
#---------------------------------------------
MONGODB_PORT=27017
MONGO_USERNAME=root
MONGO_PASSWORD=123456

#---------------------------------------------
# GO
#---------------------------------------------
GO_VERSION=1.25
GOPROXY=https://goproxy.cn,direct
GO_HOST_PORT=8081
GO_DEBUG_PORT=2345
GO_CGO_ENABLED=1
GO_INSTALL_DELVE=false
GO_PUID=1000
GO_PGID=1000
